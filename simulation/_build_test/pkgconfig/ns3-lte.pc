exec_prefix="/usr/local/bin"
libdir="/usr/local/lib"
includedir="/usr/local/include"

Name: ns3-lte
Description: 
URL: 
Version: 3.36.1
Requires:  ns3-core ns3-network ns3-spectrum ns3-stats ns3-buildings ns3-virtual-net-device ns3-point-to-point ns3-applications ns3-internet ns3-csma
Requires.private: 
Cflags: -I"${includedir}" -I/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/include -I/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr; -I/Library/Developer/CommandLineTools/SDKs/MacOSX26.sdk/usr/include/libxml2 -I/opt/homebrew/opt/python@3.14/Frameworks/Python.framework/Versions/3.14/include/python3.14 -I/opt/homebrew/include -I/opt/homebrew/Cellar/gsl/2.8/include
Libs: -L"${libdir}" -lns3.36.1-lte-optimized  -lns3.36.1-core-optimized -lns3.36.1-network-optimized -lns3.36.1-spectrum-optimized -lns3.36.1-stats-optimized -lns3.36.1-buildings-optimized -lns3.36.1-virtual-net-device-optimized -lns3.36.1-point-to-point-optimized -lns3.36.1-applications-optimized -lns3.36.1-internet-optimized -lns3.36.1-csma-optimized
Libs.private: -L"${libdir}" 
